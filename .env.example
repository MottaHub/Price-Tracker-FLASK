# Configurações do Price Tracker
# Copie este arquivo para .env e preencha com suas configurações

# Discord Webhook URL (opcional - para alertas no Discord)
# Obtenha em: https://discord.com/developers/applications -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_WEBHOOK_ID/SEU_WEBHOOK_TOKEN

# Exemplo:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789012345678/abcdefghijklmnopqrstuvwx